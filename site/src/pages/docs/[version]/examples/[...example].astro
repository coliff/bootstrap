---
import ExamplesLayout from '@layouts/ExamplesLayout.astro'
import { getConfig } from '@libs/config'
import { exampleFrontmatterSchema, getExampleNameFromPagePath } from '@libs/examples'

export async function getStaticPaths() {
  const examplesPageModules = import.meta.glob('../../../../assets/examples/**/*.astro', { eager: true })
  const examplesPages = Object.entries(examplesPageModules).map(([file, module]) => {
    return {
      file,
      ...module
    }
  })

  return examplesPages.map((examplesPage) => {
    const { default: _Content, file, url, ...props } = examplesPage
    const example = getExampleNameFromPagePath(examplesPage.file)

    try {
      exampleFrontmatterSchema.parse(props)
    } catch (error) {
      throw new Error(`Invalid frontmatter for the '${example}' example.`, { cause: error })
    }

    return {
      params: { example, version: getConfig().docs_version }
    }
  })
}

const example = Astro.params.example!
const examplesPageModules = import.meta.glob('../../../../assets/examples/**/*.astro')
const modulePath = Object.keys(examplesPageModules).find((path) => getExampleNameFromPagePath(path) === example)

if (!modulePath) {
  throw new Error(`Example module not found for '${example}'.`)
}

const exampleModule = examplesPageModules[modulePath]
const { default: Content, url, ...moduleProps } =
  typeof exampleModule === 'function' ? await exampleModule() : exampleModule
const props = exampleFrontmatterSchema.parse(moduleProps)
---

<ExamplesLayout {...props}>
  <Content />
</ExamplesLayout>
